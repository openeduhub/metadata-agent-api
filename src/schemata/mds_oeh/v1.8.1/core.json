    {
      "id": "ccm:oeh_extendedType",
      "group": "typification",
      "label": {
        "de": "Inhaltsart(en)",
        "en": "Content Type(s)"
      },
      "description": {
        "de": "Inhaltstyp der Ressource – bestimmt welche Zusatz-Felder angezeigt werden.",
        "en": "Content type of the resource – determines which additional fields are shown."
      },
      "prompt": {
        "de": "Bewerte die DARGESTELLTE RESSOURCE auf der Seite, NICHT den Website-Betreiber. Wähle den passenden Inhaltstyp: Lernmaterial (z.B. Arbeitsblätter, Videos, Audios, interaktive Übungen, OER, Simulationen, Lernspiele, Texte, Bilder), Bildungsangebot (z.B. Kurse, Seminare, Workshops, VHS-Kurse, Studiengänge, Weiterbildungen, Fortbildungen, Zertifikatsprogramme), Veranstaltung (z.B. Konferenzen, Tagungen, Theater, Lesungen, Konzerte, Aufführungen, Vorträge, Messen, Festivals, Ausstellungseröffnungen, Webinare – JEDE Seite mit konkretem Datum/Uhrzeit/Ort), Person (z.B. Autoren, Referenten, Lehrende), Organisation (z.B. Schulen, Hochschulen, Verlage – NUR wenn die Seite die Organisation SELBST vorstellt), Tool/Dienst (z.B. Software, Apps, Plattformen, digitale Werkzeuge), Beruf (z.B. Berufsbilder, Tätigkeitsfelder, Berufsorientierung), Didaktische Planung (z.B. Unterrichtsentwürfe, Methoden, Stundenpläne), Quelle (z.B. Datenportale, Repositorien, Mediatheken, Bilddatenbanken – NUR reine Sammlungs-/Portalseiten, NICHT einzelne Inhalte), KI-Prompt (z.B. Prompt-Templates, Prompt-Sammlungen).",
        "en": "Evaluate the RESOURCE PRESENTED on the page, NOT the website operator. Select the matching content type: Learning Material (e.g. worksheets, videos, audios, interactive exercises, OER, simulations, learning games, texts, images), Educational Offering (e.g. courses, seminars, workshops, degree programs, continuing education, certificate programs), Event (e.g. conferences, conventions, theater, readings, concerts, performances, lectures, fairs, festivals, exhibition openings, webinars – ANY page with specific date/time/venue), Person (e.g. authors, speakers, educators), Organization (e.g. schools, universities, publishers – ONLY if the page presents the organization ITSELF), Tool/Service (e.g. software, apps, platforms, digital tools), Occupation (e.g. job profiles, career orientation), Didactic Planning (e.g. lesson designs, methods, lesson plans), Source (e.g. data portals, repositories, media libraries, image databases – ONLY pure collection/portal pages, NOT individual content), AI Prompt (e.g. prompt templates, prompt collections)."
      },
      "system": {
        "path": "ccm:oeh_extendedType",
        "uri": "ccm:oeh_extendedType",
        "datatype": "array",
        "multiple": false,
        "required": false,
        "ask_user": false,
        "ai_fillable": false,
        "repo_field": false,
        "index": {
          "keyword": true
        },
        "vocabulary": {
