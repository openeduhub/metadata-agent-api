    {
      "id": "ccm:educationalcontext",
      "group": "typification",
      "label": {
        "de": "Bildungsstufe",
        "en": "Education Level"
      },
      "description": {
        "de": "Bildungsstufe(n) auswählen",
        "en": "Select education level(s)"
      },
      "prompt": {
        "de": "Bestimme die passende(n) Bildungsstufe(n). Wähle NUR aus den vorgegebenen Vokabular-URIs. Achte auf Alters-/Niveauhinweise: Klasse 1–4 → Primarstufe; Klasse 5–10 → Sekundarstufe I; Oberstufe/Abitur → Sekundarstufe II; Uni/FH → Hochschule. Mehrfachauswahl möglich. Gib URIs als JSON-Array zurück. Beispiele: ['http://w3id.org/openeduhub/vocabs/educationalContext/grundschule'], ['http://w3id.org/openeduhub/vocabs/educationalContext/sekundarstufe_1', 'http://w3id.org/openeduhub/vocabs/educationalContext/sekundarstufe_2'].",
        "en": "Determine the appropriate education level(s). Choose ONLY from provided vocabulary URIs. Look for age/level indicators: grades 1–4 → primary; grades 5–10 → Secondary I; upper secondary → Secondary II; university → Higher Education. Multiple selections allowed. Return URIs as JSON array. Examples: ['http://w3id.org/openeduhub/vocabs/educationalContext/grundschule'], ['http://w3id.org/openeduhub/vocabs/educationalContext/sekundarstufe_1', 'http://w3id.org/openeduhub/vocabs/educationalContext/sekundarstufe_2']."
      },
      "promptInstructions": {
        "labelExactMatch": true
      },
      "system": {
        "path": "ccm:educationalcontext",
        "uri": "ccm:educationalcontext",
        "datatype": "array",
        "multiple": true,
        "required": false,
        "ask_user": true,
        "ai_fillable": true,
        "repo_field": true,
        "index": {
          "keyword": true
        },
        "vocabulary": {
