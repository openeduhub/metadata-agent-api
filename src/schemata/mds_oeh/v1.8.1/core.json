{
  "profileId": "core:descriptive",
  "version": "1.8.1",
  "@context": {
    "schema": "https://schema.org/",
    "cclom": "https://example.org/cclom/",
    "ccm": "https://example.org/ccm/",
    "preview": "https://example.org/preview/"
  },
  "groups": [
    {
      "id": "description",
      "icon": "description",
      "label": {
        "de": "Beschreibung",
        "en": "Description"
      }
    },
    {
      "id": "typification",
      "icon": "category",
      "label": {
        "de": "Typisierung",
        "en": "Typification"
      }
    }
  ],
  "fields": [
    {
      "id": "cclom:title",
      "group": "description",
      "label": {
        "de": "Titel",
        "en": "Title"
      },
      "description": {
        "de": "Titel der Ressource",
        "en": "Title of the resource"
      },
      "examples": {
        "de": [
          "Zukunft der Hochschullehre"
        ],
        "en": [
          "Zukunft der Hochschullehre"
        ]
      },
      "prompt": {
        "de": "GENERIERE einen aussagekräftigen, eigenständigen Titel, der den Inhalt prägnant zusammenfasst. Der Titel muss ohne zusätzlichen Kontext verständlich sein. Verwende NICHT den Namen der Website oder Plattform. Vermeide generische Floskeln wie 'Überblick über…' oder 'Informationen zu…'. Maximal 80 Zeichen. Beispiele: 'Künstliche Intelligenz in der Hochschullehre', 'Photosynthese – Ablauf und Bedeutung für Ökosysteme', 'Demokratie im antiken Griechenland'.",
        "en": "GENERATE a concise, self-contained title summarizing the resource content. The title must be understandable without additional context. Do NOT use the website or platform name. Avoid generic phrases like 'Overview of…' or 'Information about…'. Maximum 80 characters. Examples: 'Artificial Intelligence in Higher Education', 'Photosynthesis – Process and Significance', 'Democracy in Ancient Greece'."
      },
      "system": {
        "path": "cclom:title",
        "uri": "cclom:title",
        "datatype": "string",
        "multiple": false,
        "required": true,
        "ask_user": true,
        "ai_fillable": true,
        "repo_field": true,
        "index": {
          "fulltext": true,
          "keyword": true
        },
        "normalization": {
          "trim": true,
          "collapseWhitespace": true
        }
      }
    },
    {
      "id": "cclom:general_description",
      "group": "description",
      "label": {
        "de": "Beschreibungstext",
        "en": "Description Text"
      },
      "description": {
        "de": "Kurzbeschreibung / Abstract",
        "en": "Short description / abstract"
      },
      "prompt": {
        "de": "GENERIERE eine informative Zusammenfassung in 2–4 Sätzen (mind. 40 Zeichen). Beschreibe den zentralen Inhalt, das Ziel und ggf. die Zielgruppe. Schreibe sachlich in dritter Person – keine Ich-Form, keine Anrede. Vermeide Wiederholungen des Titels. Beispiele: 'Das Arbeitsblatt vermittelt Grundlagen der Bruchrechnung für die Klassen 5–6. Anhand von Alltagsbeispielen üben Lernende das Kürzen und Erweitern von Brüchen.', 'Der Fachartikel analysiert den Einfluss von KI-Werkzeugen auf die Hochschuldidaktik und zeigt Chancen und Risiken anhand aktueller Studien auf.'",
        "en": "GENERATE an informative summary in 2–4 sentences (min. 40 characters). Describe the core content, purpose, and target audience. Write objectively in third person – no first person, no direct address. Avoid repeating the title. Examples: 'This worksheet teaches fraction basics for grades 5–6. Learners practice simplifying and expanding fractions using real-world examples.', 'The article analyzes the impact of AI tools on higher education pedagogy, presenting opportunities and risks based on current studies.'"
      },
      "system": {
        "path": "cclom:general_description",
        "uri": "cclom:general_description",
        "datatype": "string",
        "multiple": false,
        "required": true,
        "ask_user": true,
        "ai_fillable": true,
        "repo_field": true,
        "index": {
          "fulltext": true
        },
        "normalization": {
          "trim": true,
          "collapseWhitespace": true
        },
        "validation": {
          "minLength": 40
        }
      }
    },
    {
      "id": "cclom:general_keyword",
      "group": "typification",
      "label": {
        "de": "Schlagwörter",
        "en": "Keywords"
      },
      "description": {
        "de": "Schlagwörter (kommagetrennt)",
        "en": "Keywords (comma-separated)"
      },
      "examples": {
        "de": [
          "KI, Hochschuldidaktik",
          [
            "Künstliche Intelligenz",
            "Digitale Lehre"
          ]
        ],
        "en": [
          "KI, Hochschuldidaktik",
          [
            "Künstliche Intelligenz",
            "Digitale Lehre"
          ]
        ]
      },
      "prompt": {
        "de": "Extrahiere 3–8 fachlich relevante Schlagwörter, die den Inhalt treffend beschreiben. Verwende etablierte Fachbegriffe, keine ganzen Sätze. Jedes Schlagwort soll eigenständig suchbar sein. Vermeide zu allgemeine Begriffe wie 'Bildung' oder 'Lernen', wenn spezifischere passen. Gib ein JSON-Array zurück. Beispiele: ['Bruchrechnung', 'Mathematik', 'Klasse 5', 'Arbeitsblatt'], ['Künstliche Intelligenz', 'Hochschuldidaktik', 'Prompt Engineering', 'ChatGPT'], ['Photosynthese', 'Biologie', 'Chloroplasten', 'Lichtreaktion'].",
        "en": "Extract 3–8 subject-relevant keywords accurately describing the content. Use established technical terms, not full sentences. Each keyword should be independently searchable. Avoid overly generic terms like 'education' when more specific ones apply. Return a JSON array. Examples: ['Fractions', 'Mathematics', 'Grade 5', 'Worksheet'], ['Artificial Intelligence', 'Higher Education', 'Prompt Engineering', 'ChatGPT'], ['Photosynthesis', 'Biology', 'Chloroplasts', 'Light Reaction']."
      },
      "system": {
        "path": "cclom:general_keyword",
        "uri": "cclom:general_keyword",
        "datatype": "array",
        "multiple": true,
        "required": true,
        "ask_user": true,
        "ai_fillable": true,
        "repo_field": true,
        "index": {
          "keyword": true
        },
        "normalization": {
          "trim": true,
          "deduplicate": true,
          "collapseWhitespace": true
        }
      }
    },
    {
      "id": "ccm:wwwurl",
      "group": "description",
      "label": {
        "de": "Web-URL",
        "en": "Web URL"
      },
      "description": {
        "de": "URL der Ressource",
        "en": "URL of the resource"
      },
      "examples": {
        "de": [
          "https://www.beispiel.de/angebot"
        ],
        "en": [
          "https://www.beispiel.de/angebot"
        ]
      },
      "prompt": {
        "de": "Extrahiere die primäre, öffentlich erreichbare URL der Ressource. Verwende die kanonische URL ohne Tracking-Parameter oder Session-IDs. Muss mit http:// oder https:// beginnen. Bei mehreren URLs die Haupt-URL wählen, nicht Unterseiten-Links. Beispiele: 'https://www.goethe.de/prj/klb/de/home.html', 'https://mint-zirkel.de/2024/01/photosynthese/', 'https://www.bpb.de/kurz-knapp/lexika/das-junge-politik-lexikon/320468/demokratie/'.",
        "en": "Extract the primary, publicly accessible URL of the resource. Use the canonical URL without tracking parameters or session IDs. Must start with http:// or https://. If multiple URLs exist, choose the main resource URL, not sub-page links. Examples: 'https://www.goethe.de/prj/klb/en/home.html', 'https://mint-zirkel.de/2024/01/photosynthesis/', 'https://www.bpb.de/kurz-knapp/lexika/320468/democracy/'."
      },
      "system": {
        "path": "ccm:wwwurl",
        "uri": "ccm:wwwurl",
        "datatype": "uri",
        "multiple": false,
        "required": true,
        "ask_user": true,
        "ai_fillable": true,
        "repo_field": true,
        "index": {
          "keyword": true
        },
        "validation": {
          "pattern": "^(https?://[^\\s]+)$"
        },
        "normalization": {
          "trim": true
        }
      }
    },
    {
      "id": "preview:url",
      "group": "description",
      "label": {
        "de": "URL des Vorschaubildes",
        "en": "Preview Image URL"
      },
      "description": {
        "de": "Link zum Vorschaubild",
        "en": "Preview image link"
      },
      "examples": {
        "de": [
          "https://cdn.beispiel.de/thumbs/123.jpg"
        ],
        "en": [
          "https://cdn.beispiel.de/thumbs/123.jpg"
        ]
      },
      "prompt": {
        "de": "Extrahiere die URL eines repräsentativen Vorschaubilds (Thumbnail, Open-Graph-Image, Hero-Image). Suche nach og:image, twitter:image oder prominent eingebundenen Bildern. Nur direkte Bild-URLs mit Endung .jpg, .jpeg, .png oder .webp. Keine Platzhalter, Icons oder SVGs. Beispiele: 'https://example.com/images/og-preview.jpg', 'https://cdn.portal.de/media/header-photo.png'.",
        "en": "Extract the URL of a representative preview image (thumbnail, Open Graph image, hero image). Look for og:image, twitter:image, or prominently embedded images. Only direct image URLs ending in .jpg, .jpeg, .png, or .webp. No placeholders, icons, or SVGs. Examples: 'https://example.com/images/og-preview.jpg', 'https://cdn.portal.de/media/header-photo.png'."
      },
      "system": {
        "path": "preview:url",
        "uri": "preview:url",
        "datatype": "uri",
        "multiple": false,
        "required": false,
        "ask_user": true,
        "ai_fillable": true,
        "repo_field": true,
        "index": {
          "keyword": true
        },
        "validation": {
          "pattern": "^(https?://[^\\s]+\\.(jpg|jpeg|png|webp))$"
        },
        "normalization": {
          "trim": true
        }
      }
    },
    {
      "id": "cclom:general_language",
      "group": "description",
      "label": {
        "de": "Sprache",
        "en": "Language"
      },
      "description": {
        "de": "Sprache der Ressource",
        "en": "Resource language"
      },
      "prompt": {
        "de": "Erkenne die Hauptsprache des Textes. Gib den ISO-639-1-Code in Kleinbuchstaben zurück. Nur die dominante Sprache – nicht Sprachen aus Zitaten oder Links. Wähle aus dem vorgegebenen Vokabular. Beispiele: 'de' (deutschsprachiger Text), 'en' (englischsprachiger Text), 'fr' (französischsprachiger Text).",
        "en": "Detect the main language of the text. Return ISO 639-1 code in lowercase. Only the dominant language – not languages from quotes or links. Choose from provided vocabulary. Examples: 'de' (German text), 'en' (English text), 'fr' (French text)."
      },
      "system": {
        "path": "cclom:general_language",
        "uri": "cclom:general_language",
        "datatype": "string",
        "multiple": false,
        "required": false,
        "ask_user": true,
        "ai_fillable": true,
        "repo_field": true,
        "index": {
          "keyword": true
        },
        "validation": {
          "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
        },
